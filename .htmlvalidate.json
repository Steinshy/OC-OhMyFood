{
  "extends": ["html-validate:recommended"],
  "rules": {
    "require-sri": "off",
    "no-trailing-whitespace": "error",
    "void-style": ["error", { "style": "omit" }],
    "attr-quotes": ["error", { "style": "double" }],
    "wcag/h63": "warn",
    "wcag/h67": "warn"
  },
  "elements": {
    "meta": {
      "attributes": {
        "charset": { "required": false }
      }
    }
  }
}

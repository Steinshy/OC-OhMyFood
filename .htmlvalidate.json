{
  "extends": ["html-validate:recommended"],
  "rules": {
    "doctype-style": "off",
    "no-implicit-button-type": "warn",
    "wcag/h30": "warn",
    "require-sri": "off",
    "no-trailing-whitespace": "error",
    "void-style": ["error", { "style": "selfclosing" }],
    "attr-quotes": ["error", { "style": "double" }],
    "wcag/h63": "warn",
    "wcag/h67": "warn"
  }
}
